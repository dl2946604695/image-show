VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# 智能体 API 配置
# 注意：Cloudflare Pages Functions 读取的是 Pages 项目环境变量，不会自动读取本地 .env 文件。
WEGENT_API_KEY=your-wegent-api-key
WEGENT_BASE_URL=https://wegent.example.com/api/v1/responses
WEGENT_MODEL="Trae#摄影老师"
WEGENT_TOOL_TYPE=wegent_chat_bot
