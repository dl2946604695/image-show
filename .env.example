VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Photography teacher Agent / Zhipu BigModel
# Cloudflare Pages Functions read these from the Pages project environment.
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_MODEL=glm-4.7
ZHIPU_FALLBACK_MODELS=glm-4.5-flash
ZHIPU_TEMPERATURE=0.7
ZHIPU_RETRY_COUNT=1
ZHIPU_MAX_TOKENS=1200
